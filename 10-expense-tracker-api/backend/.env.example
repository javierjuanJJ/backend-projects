# ─── Base de Datos ────────────────────────────────────────────────────────────
# PostgreSQL - Prisma Postgres (generado por `npx prisma init --db`)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Clave secreta para firmar los tokens JWT (cambiar en producción)
JWT_SECRET="cambia-esto-por-una-clave-muy-secreta-en-produccion"
JWT_EXPIRES_IN="7d"

# ─── Next.js ──────────────────────────────────────────────────────────────────
NODE_ENV="development"
