# ─── Application ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (MySQL 8) ──────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://leaderboard:leaderboard@localhost:3306/leaderboard_system

MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=leaderboard_system
MYSQL_USER=leaderboard
MYSQL_PASSWORD=leaderboard
MYSQL_PORT=3306

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=          # Uncomment and set in production
REDIS_PORT=6379

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_MUST_BE_AT_LEAST_32_CHARACTERS_LONG
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ACCEPTED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173

# ─── Pagination defaults ─────────────────────────────────────────────────────
DEFAULT_LIMIT=10
DEFAULT_OFFSET=0

# ─── Cache ───────────────────────────────────────────────────────────────────
LEADERBOARD_CACHE_TTL=60   # seconds

# ─── Deployment (Cubepath / Coolify) ─────────────────────────────────────────
# COOLIFY_WEBHOOK_URL=https://your-coolify-instance/api/v1/deploy/webhook
# COOLIFY_TOKEN=your-coolify-api-token
# APP_URL=https://api.yourdomain.com
