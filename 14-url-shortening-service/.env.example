# Copia este archivo como .env y rellena los valores
# cp .env.example .env

# ── Base de datos ─────────────────────────────────────────────────
# PostgreSQL (Prisma Postgres, Railway, Supabase, Neon, local...)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Ejemplos:
# Local:    postgresql://postgres:password@localhost:5432/shorturl
# Railway:  postgresql://postgres:xxxx@containers-us-west-xxx.railway.app:7777/railway
# Supabase: postgresql://postgres:xxxx@db.xxxx.supabase.co:5432/postgres

# ── Servidor ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
