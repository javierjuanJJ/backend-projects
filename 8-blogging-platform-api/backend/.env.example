# Copia como .env y rellena con tus credenciales

# ── Base de datos PostgreSQL ──────────────────────────────────
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/posts_db?schema=public"
# Prisma Postgres cloud:
# DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=TU_API_KEY"

# ── JWT ───────────────────────────────────────────────────────
# Genera un secreto seguro con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cambia_esto_por_un_secreto_largo_y_aleatorio_de_minimo_32_chars"
JWT_EXPIRES_IN="7d"
