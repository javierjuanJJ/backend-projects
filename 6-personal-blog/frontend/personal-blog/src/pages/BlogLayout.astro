---
// src/layouts/BlogLayout.astro
export interface Props {
  title?: string;
  description?: string;
}
const { title = 'Mi Blog', description = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0d0d0f;
      --surface:   #141418;
      --surface2:  #1c1c22;
      --border:    #2a2a35;
      --border2:   #353542;
      --text:      #e8e8f0;
      --muted:     #72728a;
      --subtle:    #3a3a4a;
      --accent:    #7c6af7;
      --accent2:   #a594ff;
      --green:     #4ade80;
      --red:       #f87171;
      --serif:     'DM Serif Display', Georgia, serif;
      --sans:      'DM Sans', system-ui, sans-serif;
      --mono:      'DM Mono', monospace;
      --r:         6px;
      --r-lg:      12px;
    }

    html { font-size: 16px; scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-weight: 300;
      line-height: 1.8;
      min-height: 100vh;
    }

    /* Noise texture overlay */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0;
      pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      background-size: 200px;
      opacity: .5;
    }

    body > * { position: relative; z-index: 1; }

    /* ─── Header ─── */
    .site-header {
      border-bottom: 1px solid var(--border);
      background: rgba(13,13,15,.85);
      backdrop-filter: blur(16px);
      position: sticky; top: 0; z-index: 100;
    }
    .site-header__inner {
      max-width: 1200px; margin: 0 auto;
      padding: 1rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .site-logo {
      font-family: var(--serif);
      font-size: 1.4rem;
      color: var(--text);
      text-decoration: none;
      letter-spacing: -.02em;
      display: flex; align-items: center; gap: .5rem;
    }
    .site-logo__dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--accent);
      display: inline-block;
      box-shadow: 0 0 12px var(--accent);
    }
    .site-nav { display: flex; gap: 1rem; align-items: center; }
    .site-nav a {
      font-size: .82rem; font-weight: 500;
      letter-spacing: .05em; text-transform: uppercase;
      color: var(--muted); text-decoration: none;
      padding: .4rem .7rem; border-radius: var(--r);
      transition: color .2s, background .2s;
    }
    .site-nav a:hover { color: var(--text); background: var(--surface2); }
    .site-nav .btn-cta {
      background: var(--accent); color: #fff !important;
      box-shadow: 0 0 20px rgba(124,106,247,.35);
    }
    .site-nav .btn-cta:hover { background: var(--accent2) !important; }

    /* ─── Main ─── */
    .page-main {
      max-width: 1200px; margin: 0 auto;
      padding: 3.5rem 2rem 6rem;
    }

    /* ─── Footer ─── */
    .site-footer {
      border-top: 1px solid var(--border);
      text-align: center;
      padding: 2rem;
      font-size: .78rem;
      color: var(--muted);
      letter-spacing: .04em;
    }

    /* ─── Prose ─── */
    .prose {
      font-family: var(--sans);
      font-size: 1.05rem;
      color: var(--text);
      max-width: 70ch;
    }
    .prose h1,.prose h2,.prose h3 {
      font-family: var(--serif);
      color: var(--text);
      line-height: 1.2;
      margin: 2.5rem 0 .8rem;
    }
    .prose h1 { font-size: 2.2rem; }
    .prose h2 { font-size: 1.65rem; border-bottom: 1px solid var(--border); padding-bottom: .5rem; }
    .prose h3 { font-size: 1.25rem; }
    .prose p { margin-bottom: 1.4rem; color: #c0c0d0; }
    .prose a { color: var(--accent2); text-decoration: none; border-bottom: 1px solid rgba(165,148,255,.3); }
    .prose a:hover { border-color: var(--accent2); }
    .prose code {
      background: var(--surface2); color: var(--accent2);
      padding: .15em .45em; border-radius: 4px;
      font-family: var(--mono); font-size: .88em;
      border: 1px solid var(--border);
    }
    .prose pre {
      background: var(--surface); color: var(--text);
      padding: 1.4rem; border-radius: var(--r-lg);
      overflow-x: auto; margin-bottom: 1.4rem;
      border: 1px solid var(--border);
    }
    .prose pre code { background: none; border: none; padding: 0; color: inherit; }
    .prose blockquote {
      border-left: 3px solid var(--accent);
      padding-left: 1.25rem; margin: 1.5rem 0;
      color: var(--muted); font-style: italic;
    }
    .prose ul,.prose ol { padding-left: 1.5rem; margin-bottom: 1.4rem; }
    .prose li { margin-bottom: .5rem; color: #c0c0d0; }
    .prose strong { color: var(--text); font-weight: 600; }
    .prose hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }

    /* ─── Tag pill ─── */
    .tag {
      display: inline-block;
      font-family: var(--mono); font-size: .68rem;
      font-weight: 500; letter-spacing: .06em;
      background: rgba(124,106,247,.12);
      color: var(--accent2);
      border: 1px solid rgba(124,106,247,.25);
      padding: .2rem .65rem; border-radius: 20px;
    }

    /* ─── Animations ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .animate { animation: fadeUp .45s ease both; }
    .delay-1 { animation-delay: .08s; }
    .delay-2 { animation-delay: .16s; }
    .delay-3 { animation-delay: .24s; }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="site-header__inner">
      <a href="/" class="site-logo">
        <span class="site-logo__dot"></span>
        bitácora
      </a>
      <nav class="site-nav">
        <a href="/">Posts</a>
        <a href="/admin" class="btn-cta">+ Nuevo</a>
      </nav>
    </div>
  </header>

  <main class="page-main">
    <slot />
  </main>

  <footer class="site-footer">
    © {new Date().getFullYear()} bitácora — construido con Astro
  </footer>
</body>
</html>
