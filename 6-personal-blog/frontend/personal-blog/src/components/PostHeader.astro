---
// src/components/PostHeader.astro
export interface Props {
  title: string;
  date?: string | null;
  description?: string;
  tags?: string[];
  id: string;
}

const { title, date, description, tags = [], id } = Astro.props;

const formatted = date
  ? new Date(date).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---

<header class="post-header animate">
  <div class="post-header__nav">
    <a href="/" class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Todos los posts
    </a>
    <a href={`/admin/edit/${id}`} class="edit-link">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      Editar
    </a>
  </div>

  {tags.length > 0 && (
    <div class="post-header__tags animate delay-1">
      {tags.map(t => <span class="tag">{t}</span>)}
    </div>
  )}

  <h1 class="post-header__title animate delay-1">{title}</h1>

  {description && (
    <p class="post-header__desc animate delay-2">{description}</p>
  )}

  {formatted && (
    <div class="post-header__meta animate delay-2">
      <span class="meta-item">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <time>{formatted}</time>
      </span>
    </div>
  )}

  <div class="post-header__rule animate delay-3"></div>
</header>

<style>
  .post-header {
    margin-bottom: 3rem;
  }

  .post-header__nav {
    display: flex; align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .back-link, .edit-link {
    display: inline-flex; align-items: center; gap: .4rem;
    font-size: .78rem; font-weight: 500;
    letter-spacing: .05em; text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--r);
    padding: .4rem .75rem;
    transition: background .2s, color .2s;
  }
  .back-link { color: var(--muted); }
  .back-link:hover { color: var(--text); background: var(--surface2); }

  .edit-link {
    color: var(--accent2);
    border: 1px solid rgba(124,106,247,.3);
    background: rgba(124,106,247,.07);
  }
  .edit-link:hover { background: rgba(124,106,247,.15); }

  .post-header__tags {
    display: flex; gap: .5rem; flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .post-header__title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    line-height: 1.12;
    letter-spacing: -.04em;
    color: var(--text);
    margin-bottom: 1.1rem;
  }

  .post-header__desc {
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 62ch;
    margin-bottom: 1rem;
  }

  .post-header__meta {
    display: flex; align-items: center; gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .meta-item {
    display: flex; align-items: center; gap: .4rem;
    font-family: var(--mono); font-size: .75rem;
    color: var(--muted);
  }

  .post-header__rule {
    width: 100%; height: 1px;
    background: linear-gradient(90deg, var(--accent) 0%, transparent 60%);
    margin-top: 1rem;
  }
</style>
