---
// src/components/PostCard.astro
export interface Props {
  id: string;
  title: string;
  date?: string | null;
  description?: string;
  tags?: string[];
  index?: number; // for staggered animation
}

const { id, title, date, description, tags = [], index = 0 } = Astro.props;

const formatted = date
  ? new Date(date).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })
  : null;

const delay = Math.min(index * 0.08, 0.4);
---

<article class="post-card animate" style={`animation-delay:${delay}s`}>
  <div class="post-card__inner">
    <div class="post-card__top">
      <div class="post-card__tags">
        {tags.map(t => <span class="tag">{t}</span>)}
      </div>
      {formatted && <time class="post-card__date">{formatted}</time>}
    </div>

    <h2 class="post-card__title">
      <a href={`/posts/${id}`}>{title}</a>
    </h2>

    {description && <p class="post-card__desc">{description}</p>}

    <div class="post-card__footer">
      <a href={`/posts/${id}`} class="post-card__link">
        Leer <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M1 6h10M7 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href={`/admin/edit/${id}`} class="post-card__edit" title="Editar">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      </a>
    </div>
  </div>
</article>

<style>
  .post-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    transition: border-color .25s, transform .25s, box-shadow .25s;
    overflow: hidden;
  }
  .post-card:hover {
    border-color: var(--border2);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,0,0,.35), 0 0 0 1px rgba(124,106,247,.1);
  }

  .post-card__inner {
    padding: 1.75rem;
    display: flex; flex-direction: column; gap: .85rem;
    height: 100%;
  }

  .post-card__top {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: .75rem;
  }

  .post-card__tags { display: flex; gap: .4rem; flex-wrap: wrap; flex: 1; }

  .post-card__date {
    font-family: var(--mono);
    font-size: .7rem; color: var(--muted);
    white-space: nowrap; flex-shrink: 0;
    margin-top: .15rem;
  }

  .post-card__title {
    font-family: var(--serif);
    font-size: 1.5rem;
    line-height: 1.25;
    letter-spacing: -.025em;
    flex: 1;
  }
  .post-card__title a {
    color: var(--text); text-decoration: none;
    transition: color .2s;
  }
  .post-card__title a:hover { color: var(--accent2); }

  .post-card__desc {
    font-size: .9rem;
    color: var(--muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card__footer {
    display: flex; align-items: center;
    justify-content: space-between;
    margin-top: auto; padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .post-card__link {
    display: inline-flex; align-items: center; gap: .45rem;
    font-size: .78rem; font-weight: 600;
    letter-spacing: .05em; text-transform: uppercase;
    color: var(--accent2); text-decoration: none;
    transition: gap .2s;
  }
  .post-card__link:hover { gap: .75rem; }

  .post-card__edit {
    color: var(--subtle);
    text-decoration: none;
    padding: .35rem;
    border-radius: var(--r);
    transition: color .2s, background .2s;
    display: flex;
  }
  .post-card__edit:hover { color: var(--muted); background: var(--surface2); }
</style>
