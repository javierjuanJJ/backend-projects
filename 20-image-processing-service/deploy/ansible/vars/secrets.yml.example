# deploy/ansible/vars/secrets.yml
# Encrypt this file with: ansible-vault encrypt deploy/ansible/vars/secrets.yml
# Edit with:              ansible-vault edit deploy/ansible/vars/secrets.yml

ghcr_username: YOUR_GITHUB_USERNAME
ghcr_token: YOUR_GITHUB_PAT_WITH_PACKAGES_READ

postgres_user: pguser
postgres_password: CHANGE_ME_strong_password
postgres_db: imageapi

jwt_secret: CHANGE_ME_64_char_random_hex_string
jwt_expires_in: "7d"

rabbitmq_user: rmquser
rabbitmq_pass: CHANGE_ME_rabbitmq_password

stripe_secret_key: sk_live_...
stripe_webhook_secret: whsec_...

base_url: https://yourdomain.com
cors_allowed_origins: "https://yourdomain.com,https://www.yourdomain.com"

max_file_size_mb: 10
rate_limit_window_ms: 900000
rate_limit_max: 20
