# Generated by Ansible — do not edit manually on the server
NODE_ENV=production
PORT=3000
BASE_URL={{ base_url }}

DATABASE_URL=postgresql://{{ postgres_user }}:{{ postgres_password }}@postgres:5432/{{ postgres_db }}
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB={{ postgres_db }}

JWT_SECRET={{ jwt_secret }}
JWT_EXPIRES_IN={{ jwt_expires_in | default('7d') }}

RABBITMQ_URL=amqp://{{ rabbitmq_user }}:{{ rabbitmq_pass }}@rabbitmq:5672
RABBITMQ_USER={{ rabbitmq_user }}
RABBITMQ_PASS={{ rabbitmq_pass }}

STRIPE_SECRET_KEY={{ stripe_secret_key }}
STRIPE_WEBHOOK_SECRET={{ stripe_webhook_secret }}

UPLOAD_DIR=/app/uploads
CACHE_DIR=/app/cache
MAX_FILE_SIZE_MB={{ max_file_size_mb | default(10) }}
RATE_LIMIT_WINDOW_MS={{ rate_limit_window_ms | default(900000) }}
RATE_LIMIT_MAX={{ rate_limit_max | default(20) }}
CORS_ALLOWED_ORIGINS={{ cors_allowed_origins }}
