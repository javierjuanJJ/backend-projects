# ─── Visual Crossing Weather API ───────────────────────────────────────────────
VISUALCROSSING_API_KEY=YOUR_API_KEY_HERE

# ─── Redis Connection ───────────────────────────────────────────────────────────
# Formato: redis[s]://[[username][:password]@][host][:port][/db-number]
REDIS_URL=redis://localhost:6379

# ─── Cache TTL (segundos) ──────────────────────────────────────────────────────
# 12 horas = 43200 segundos
CACHE_TTL_SECONDS=43200
