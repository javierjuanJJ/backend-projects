# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos (Prisma) ─────────────────────────────────────────────────────
# SQLite (desarrollo local — no necesita instalación)
DATABASE_URL="file:./dev.db"

# PostgreSQL (producción)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/weather_db"

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Con auth: redis://:password@localhost:6379
# TLS (Redis Cloud): rediss://user:pass@host:6380

# ── Visual Crossing Weather API ────────────────────────────────────────────────
VISUALCROSSING_API_KEY=YOUR_API_KEY_HERE

# ── Caché ──────────────────────────────────────────────────────────────────────
# 12 horas en segundos
CACHE_TTL_SECONDS=43200
