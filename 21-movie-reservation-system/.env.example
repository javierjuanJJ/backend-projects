# ============================================================
# Movie Reservation System — Variables de Entorno
# Copia este fichero como .env y rellena tus credenciales
# ¡NUNCA subas el fichero .env a git!
# ============================================================

# --- Aplicación ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# --- Base de datos (MySQL) ---
DATABASE_URL="mysql://movie_user:movie_pass@localhost:3306/movie_reservation_db"

# --- JWT ---
JWT_ACCESS_SECRET=cambia_este_secreto_muy_largo_y_aleatorio_access
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambia_este_secreto_muy_largo_y_aleatorio_refresh
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:1234

# --- Admin inicial (seed) ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@cinema.com
ADMIN_PASSWORD=Admin1234!

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- SendGrid ---
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_FROM_EMAIL=noreply@cinema.com
SENDGRID_FROM_NAME=Cinema Reservations

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- QR Code ---
QR_BASE_URL=http://localhost:3000/reservations

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
