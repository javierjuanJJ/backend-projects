{
  "name": "movie-reservation-api",
  "version": "1.0.0",
  "description": "Movie Reservation System — REST API with Next.js + Express + Prisma",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --ext .js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sendgrid/mail": "^8.1.3",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "next": "^15.0.3",
    "qrcode": "^1.5.4",
    "stripe": "^17.3.1",
    "twilio": "^5.3.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^9.15.0",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "vitest": "^2.1.5"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
