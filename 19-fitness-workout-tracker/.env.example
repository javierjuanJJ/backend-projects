# ============================================================
# WORKOUT TRACKER API — Variables de Entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# ── Aplicación ────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Base de datos (PostgreSQL) ────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:changeme@localhost:5432/workout_tracker?schema=public"

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=supersecreto_cambia_esto_en_produccion_min32chars
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────
# Orígenes permitidos separados por comas
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Bcrypt ────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── PostgreSQL (Docker Compose) ───────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=workout_tracker

# ── Cubepath Deploy ───────────────────────────────────────
CUBEPATH_API_KEY=your_cubepath_api_key
CUBEPATH_APP_NAME=workout-tracker
CUBEPATH_REGION=eu-west-1

# ── Docker Registry ───────────────────────────────────────
REGISTRY=ghcr.io
IMAGE_NAME=your-org/workout-tracker
IMAGE_TAG=latest
